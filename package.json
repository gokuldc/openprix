{
  "name": "openprix-client",
  "private": true,
  "version": "2.0.0-RC2",
  "description": "The Operating System for Modern Engineering & Construction Firms.",
  "author": "Gokul DC",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently --kill-others \"vite\" \"py -m uvicorn main:app --app-dir .. --port 8000\"",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "dev:tauri": "tauri dev",
    "build:tauri": "tauri build"
  },
  "build": {
    "appId": "com.openprix.estimator",
    "productName": "OPENPRIX",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "license": "LICENSE"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "MASTER_DB_SAMPLE.json"
    ]
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@mui/icons-material": "^6.4.1",
    "@mui/material": "^6.4.1",
    "@tanstack/react-query": "^5.100.10",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "vite": "^6.4.1",
    "wait-on": "^8.0.2"
  }
}
